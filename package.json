{
  "name": "upsurge-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Upsurge — multi-tenant AI voice-agent orchestration platform (Retell AI + FUB/HighLevel)",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/lib/**/*.test.ts",
    "db:apply-pending": "node scripts/apply-migrations-api.mjs",
    "db:apply-0007": "node scripts/apply-0007.mjs",
    "db:apply-0009": "node scripts/apply-0009.mjs",
    "db:apply-0010": "node scripts/apply-0010.mjs",
    "db:verify-schema": "node scripts/verify-schema.mjs",
    "worker": "tsx watch worker/index.ts",
    "worker:prod": "tsx worker/index.ts",
    "poll:doctor": "tsx scripts/poll-doctor.ts",
    "report:fulfillment": "tsx scripts/fulfillment-report.ts",
    "provision:agent": "tsx scripts/provision-agent.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "bullmq": "^5.12.0",
    "dotenv": "^16.4.5",
    "ioredis": "5.10.1",
    "lucide-react": "^0.525.0",
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "retell-sdk": "^4.14.0",
    "tsx": "^4.16.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4"
  }
}
