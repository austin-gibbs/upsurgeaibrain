# =============================================================================
# UpSurge environment template. Copy to .env.local and fill in real values.
#   cp .env.example .env.local
# Every key below is read by the code (see referenced files). NEXT_PUBLIC_*
# vars are exposed to the browser; everything else is server/worker-only.
# =============================================================================

# --- Supabase -----------------------------------------------------------------
# Project API settings: Supabase Dashboard > Project Settings > API.
# URL + anon key are public (RLS-scoped client). Service role key is SECRET and
# bypasses RLS — server/worker only, never sent to the browser.
# Used by: src/lib/supabase/{client,server,middleware}.ts
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Optional — only needed to apply migrations via scripts/apply-migrations-api.mjs
# or `npx supabase db query --linked`. Create at Dashboard → Account → Access Tokens.
# SUPABASE_ACCESS_TOKEN=

# --- Redis (BullMQ queue) -----------------------------------------------------
# Local Docker: redis://localhost:6379  |  Upstash/hosted TLS: rediss://...
# Optional — defaults to redis://localhost:6379 if unset.
# Used by: src/lib/queue/connection.ts
REDIS_URL=redis://localhost:6379

# --- Retell AI ----------------------------------------------------------------
# API key: Retell Dashboard > API Keys.
# Webhook secret: the signing secret for your agent's webhook (HMAC-SHA256).
# Used by: src/lib/retell/client.ts
RETELL_API_KEY=your-retell-api-key
RETELL_WEBHOOK_SECRET=your-retell-webhook-signing-secret

# --- Credential encryption ----------------------------------------------------
# AES-256-GCM key for CRM creds at rest. MUST decode to exactly 32 bytes.
# Generate: openssl rand -base64 32
# Used by: src/lib/crypto.ts
CREDENTIALS_ENCRYPTION_KEY=base64-32-byte-key

# --- Cron ---------------------------------------------------------------------
# Bearer token guarding the external-cron poll endpoint. Any strong random
# string. Only needed when USE_EXTERNAL_CRON=true.
# Generate: openssl rand -hex 32
# Used by: src/app/api/cron/daily-poll/route.ts
CRON_SECRET=your-cron-secret

# --- Anthropic (V2 memory) ----------------------------------------------------
# Optional. Enables Haiku transcript summarization for agent memory.
# Without it, memory falls back to deterministic concatenation (still runs).
# Used by: src/lib/engine/memory.ts
ANTHROPIC_API_KEY=

# --- HighLevel OAuth ----------------------------------------------------------
# App-level credentials from your HighLevel Marketplace app (Settings > Apps).
# Required for HighLevel agents: tokens are short-lived and auto-refreshed using
# these. Register the redirect URI {NEXT_PUBLIC_APP_URL}/api/oauth/crm/callback
# in the Marketplace app. Used by: src/lib/crm/highlevel-oauth.ts
HIGHLEVEL_CLIENT_ID=
HIGHLEVEL_CLIENT_SECRET=

# OPTIONAL. Space- or comma-separated OAuth scopes requested at connect time.
# Leave blank to use the code defaults (see DEFAULT_HIGHLEVEL_OAUTH_SCOPES in
# src/lib/crm/highlevel-oauth.ts and docs/HIGHLEVEL_APP_SETUP.md). Only set this
# to align the requested scopes with what your Marketplace app is actually
# registered for — requesting a scope the app lacks makes HighLevel reject the
# connect at the "choose a location" screen. Every scope listed here must be
# registered on the Marketplace app.
HIGHLEVEL_OAUTH_SCOPES=

# Call-type Conversation Provider ID from the connected HighLevel sub-account
# (Settings > Conversation Providers). Required for playable call logs with a
# recording play button on the contact — without it, only a note with a link is
# written. For multiple HighLevel locations, prefer the JSON map keyed by
# locationId so one tenant's provider install does not break another tenant.
# Set on Vercel (webhook handler) AND Railway (worker). Used by:
# src/lib/crm/highlevel.ts
HIGHLEVEL_CALL_PROVIDER_IDS={"locationId":"providerId"}
HIGHLEVEL_CALL_PROVIDER_ID=

# --- Scheduling ---------------------------------------------------------------
# Leave unset/false to let the worker run its own 60s scheduler tick.
# Set true to drive polling from an external cron hitting /api/cron/daily-poll
# (must be listed in vercel.json). Vercel also runs /api/cron/daily-poll every
# minute as a redundant scheduler even when the worker internal tick is active.
# Used by: worker/index.ts, src/app/api/cron/daily-poll/route.ts
USE_EXTERNAL_CRON=false

# --- App URL ------------------------------------------------------------------
# Public base URL of the app. Used when configuring the Retell webhook target
# ({NEXT_PUBLIC_APP_URL}/api/webhooks/retell). Local default below.
NEXT_PUBLIC_APP_URL=http://localhost:3000
